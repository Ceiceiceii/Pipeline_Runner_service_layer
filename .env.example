# Pipeline Runner starter kit — configuration knobs.
#
# Copy to `.env` and edit, or export these as environment variables.
# Every value below is a tunable knob; the defaults model a realistic system
# where GPU cold starts dwarf job durations, so warm-pool policy matters.
#
# All variables are prefixed with PIPELINE_KIT_.

# --- Reproducibility ----------------------------------------------------------
# A single integer seed drives every random decision (failures, jitter, bursts).
# The same seed reproduces a run exactly, regardless of asyncio interleaving.
PIPELINE_KIT_SEED=0

# --- Per-step latency (seconds) and failure rate (0.0–1.0) --------------------
# segment + remove_bg are CPU-bound: cheap, fast, and "always available" (no
# failures by default). generate_multiview + fit_to_last are GPU-bound: slower
# and flaky (transient errors), and must run on the GPU pool.
PIPELINE_KIT_SEGMENT_DURATION_S=0.5
PIPELINE_KIT_SEGMENT_FAILURE_RATE=0.0
PIPELINE_KIT_REMOVE_BG_DURATION_S=0.8
PIPELINE_KIT_REMOVE_BG_FAILURE_RATE=0.0
PIPELINE_KIT_MULTIVIEW_DURATION_S=8.0
PIPELINE_KIT_MULTIVIEW_FAILURE_RATE=0.1
PIPELINE_KIT_FIT_TO_LAST_DURATION_S=12.0
PIPELINE_KIT_FIT_TO_LAST_FAILURE_RATE=0.1

# Fractional latency jitter applied to every step (0.2 => actual duration is a
# deterministic draw in [0.8x, 1.2x]). Keeps observed p50/p95 from being a
# constant you can hard-code — you have to measure it.
PIPELINE_KIT_LATENCY_JITTER=0.2

# Probability that a step fails *permanently* (non-retryable) on every attempt.
# Defaults to 0; raise it to exercise "stop retrying" logic.
PIPELINE_KIT_PERMANENT_FAILURE_RATE=0.0

# --- GPU pool / cost model ----------------------------------------------------
# Number of GPU worker slots (hard cap on concurrent GPU jobs).
PIPELINE_KIT_MAX_WORKERS=4
# Cold-start warm-up delay is drawn per warm-up from [min, max] seconds.
PIPELINE_KIT_COLD_START_MIN_S=30.0
PIPELINE_KIT_COLD_START_MAX_S=60.0
# Dollars per second a worker costs while warm (warming, idle, OR busy).
PIPELINE_KIT_COST_PER_SECOND=0.0003

# --- Burst workload generator -------------------------------------------------
# Arrivals follow a Poisson process whose rate switches between a quiet baseline
# and a burst spike, repeated n_bursts times.
PIPELINE_KIT_BASE_RATE=0.2          # requests/sec during quiet periods
PIPELINE_KIT_BURST_RATE=5.0         # requests/sec during a burst
PIPELINE_KIT_QUIET_DURATION_S=30.0  # length of each quiet period
PIPELINE_KIT_BURST_DURATION_S=10.0  # length of each burst
PIPELINE_KIT_N_BURSTS=3             # number of quiet+burst cycles

# --- Time ---------------------------------------------------------------------
# Compresses simulated time during real-clock runs: 1.0 = real time, 60.0 makes
# a 60s cold start really sleep 1s. Cost stays correct because the pool and the
# workload driver read the same clock.
PIPELINE_KIT_TIME_SCALE=1.0
